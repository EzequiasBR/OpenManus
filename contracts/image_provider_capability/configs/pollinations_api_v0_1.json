  "endpoint_modes": [
    {
      "mode_id": "pollinations_get_image_prompt",
      "mode_type": "text_to_image_get",
      "method": "GET",
      "base_url": "https://gen.pollinations.ai",
      "path_template": "/image/{prompt}",
      "endpoint_version": "unversioned",
      "request_format": "query_params",
      "response_format": "binary_image",
      "supported": true,
      "requires_auth": false,
      "notes": "Endpoint público GET. Auth pode ser passada via query key, mas o endpoint funciona sem auth dependendo da política do provider. Parâmetros adicionais via query string: width, height, seed, model, safe, transparent."
    },
    {
      "mode_id": "pollinations_post_images_generations",
      "mode_type": "text_to_image_post_json",
      "method": "POST",
      "base_url": "https://gen.pollinations.ai",
      "path_template": "/v1/images/generations",
      "endpoint_version": "v1",
      "request_format": "json_body",
      "response_format": "json",
      "supported": true,
      "requires_auth": true,
      "notes": "Endpoint OpenAI-compatible. Aceita JSON body com prompt, model, n, size, response_format (url|b64_json), seed, quality, safe. Retorna CreateImageResponse JSON."
    },
    {
      "mode_id": "pollinations_post_images_edits",
      "mode_type": "image_edit_multipart",
      "method": "POST",
      "base_url": "https://gen.pollinations.ai",
      "path_template": "/v1/images/edits",
      "endpoint_version": "v1",
      "request_format": "multipart_form",
      "response_format": "json",
      "supported": true,
      "requires_auth": true,
      "notes": "Endpoint de edição. Aceita multipart com imagem de entrada e prompt. Mask não documentado explicitamente."
    }
  ],
