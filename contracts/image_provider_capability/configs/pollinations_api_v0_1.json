    {
      "limitation_id": "negative_prompt_absent",
      "severity": "medium",
      "description": "A API Pollinations.ai não possui campo negative_prompt. Restrições negativas devem ser inseridas no prompt principal, o que reduz a precisão semântica.",
      "affected_capabilities": ["negative_prompt"],
      "mitigation": "Aplicar flatten_to_prompt via formatting policy. Registrar perda em loss_report para que o Fidelity Gate possa alertar o usuário."
    },
    {
      "limitation_id": "model_required_by_local_policy",
      "severity": "medium",
      "description": "A documentação indica que model é opcional (default zimage/flux), mas política local exige envio explícito para evitar ambiguidade entre a tool atual (que não envia model) e a API real (que suporta múltiplos modelos).",
      "affected_capabilities": ["model"],
      "mitigation": "Política local: 'prefer_local_policy' em caso de conflito. A LLM Formatting Layer deve sempre incluir model no payload normalizado."
    },
    {
      "limitation_id": "n_limited_to_one",
      "severity": "low",
      "description": "O campo n é aceito no POST mas limitado a 1. Não é possível gerar múltiplas imagens por requisição na API Pollinations.",
      "affected_capabilities": ["n"],
      "mitigation": "Documentar como supported_limited. Se múltiplas imagens forem necessárias, o sistema deve fazer várias requisições."
    },
    {
      "limitation_id": "mask_not_documented",
      "severity": "high",
      "description": "O endpoint /v1/images/edits existe, mas o campo mask (máscara para inpainting) não está documentado na APIDOCS.md. Inpainting com máscara personalizada pode não ser suportado.",
      "affected_capabilities": ["mask", "reference_image"],
      "mitigation": "Não enviar mask. Usar apenas image + prompt para edits. Registrar em loss_report se mask for solicitada."
    },
    {
      "limitation_id": "generation_metadata_incomplete",
      "severity": "medium",
      "description": "Metadados completos de geração (seed_used, model_used, revised_prompt, width, height) não são garantidos na resposta da API POST.",
      "affected_capabilities": ["metadata_request", "seed_used", "model_used", "revised_prompt", "width_height_metadata"],
      "mitigation": "Extração de metadados deve ser considerada best-effort. O NormalizedImageResult deve preencher campos como null quando não disponíveis."
    },
    {
      "limitation_id": "get_prompt_url_limit",
      "severity": "low",
      "description": "O endpoint GET /image/{prompt} coloca o prompt no path da URL, o que tem limite prático de tamanho de URL HTTP (tipicamente ~2000-8000 caracteres dependendo do cliente/servidor).",
      "affected_capabilities": ["prompt"],
      "mitigation": "Usar POST para prompts longos (>1000 caracteres). O capability map registra max_prompt_chars como 32000 com scope post_only."
