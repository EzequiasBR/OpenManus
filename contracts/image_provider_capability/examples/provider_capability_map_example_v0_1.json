{
  "$schema": "https://github.com/anomalyco/OpenManus/contracts/image_provider_capability/schemas/image_provider_capability_map.schema.json",
  "schema_version": "0.1.0",
  "provider": {
    "provider_id": "mock_image_provider",
    "provider_name": "Mock Image Provider (exemplo didático)",
    "provider_kind": "mock",
    "provider_status": "experimental"
  },
  "capability_map": {
    "capability_map_id": "mock_provider_example_v0_1",
    "capability_map_version": "0.1.0",
    "capability_map_status": "draft",
    "scope": "mock",
    "description": "Exemplo didático de capability map para um provider mock. Usado para demonstrar a estrutura do schema sem depender de APIs reais.",
    "documentation_refs": []
  },
  "endpoint_modes": [
    {
      "mode_id": "mock_text_to_image_json",
      "mode_type": "text_to_image_post_json",
      "method": "POST",
      "base_url": "https://mock-image-api.example.com",
      "path_template": "/v1/images/generations",
      "endpoint_version": "v1",
      "request_format": "json_body",
      "response_format": "json",
      "supported": true,
      "requires_auth": false,
      "notes": "Endpoint mock que aceita JSON e retorna JSON. Não requer autenticação."
    }
